{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://review-surfaces.local/schemas/human_review.schema.v1.json",
  "title": "review-surfaces human review cockpit",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "mode",
    "verdict",
    "summary",
    "narrative",
    "semantic_facts",
    "review_queue",
    "blockers",
    "questions",
    "suggested_comments",
    "trust_audit",
    "risk_lens_findings",
    "intent_mismatch",
    "review_routes",
    "since_last_review",
    "coverage_evidence",
    "review_plan",
    "change_graph",
    "reading_order",
    "evidence_cards",
    "test_plan",
    "skim_safe",
    "feedback_effects",
    "generated_from"
  ],
  "properties": {
    "schema_version": {
      "const": "review-surfaces.human_review.v1"
    },
    "mode": {
      "enum": ["pr", "repo"]
    },
    "verdict": {
      "type": "object",
      "additionalProperties": true,
      "required": ["decision", "confidence", "reasons"],
      "properties": {
        "decision": {
          "enum": [
            "probably_safe",
            "reviewable_with_attention",
            "needs_author_clarification",
            "block_before_merge",
            "no_signal"
          ]
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "reasons": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/verdictReason"
          }
        }
      }
    },
    "summary": {
      "type": "string",
      "maxLength": 2000
    },
    "narrative": {
      "$ref": "#/$defs/changeNarrative"
    },
    "semantic_facts": {
      "$ref": "#/$defs/semanticChangeFacts"
    },
    "review_queue": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reviewQueueItem"
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/blocker"
      }
    },
    "questions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/question"
      }
    },
    "suggested_comments": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/suggestedComment"
      }
    },
    "trust_audit": {
      "$ref": "#/$defs/trustAudit"
    },
    "risk_lens_findings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/riskLensFinding"
      }
    },
    "intent_mismatch": {
      "$ref": "#/$defs/intentMismatch"
    },
    "review_routes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/reviewRoute"
      }
    },
    "evidence_cards": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidenceCard"
      }
    },
    "since_last_review": {
      "$ref": "#/$defs/sinceLastReview"
    },
    "review_plan": {
      "type": "object",
      "additionalProperties": true,
      "required": ["enabled", "read", "skim", "defer"],
      "properties": {
        "enabled": { "type": "boolean" },
        "budget_minutes": { "type": "integer", "minimum": 1 },
        "read": { "type": "array", "items": { "$ref": "#/$defs/reviewPlanItem" } },
        "skim": { "type": "array", "items": { "$ref": "#/$defs/reviewPlanItem" } },
        "defer": { "type": "array", "items": { "$ref": "#/$defs/reviewPlanItem" } }
      }
    },
    "change_graph": {
      "type": "object",
      "additionalProperties": true,
      "required": ["nodes", "halo_nodes", "edges", "clusters"],
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["path", "churn_added", "churn_removed", "status", "cluster"],
            "properties": {
              "path": { "type": "string" },
              "old_path": { "type": "string" },
              "churn_added": { "type": "integer", "minimum": 0 },
              "churn_removed": { "type": "integer", "minimum": 0 },
              "status": { "enum": ["added", "modified", "deleted", "renamed"] },
              "cluster": { "type": "string" },
              "lens": {
                "enum": [
                  "api_contract",
                  "security_privacy",
                  "llm_trust_boundary",
                  "test_evidence",
                  "reviewer_ux",
                  "cache_provenance",
                  "supply_chain",
                  "custom"
                ]
              }
            }
          }
        },
        "halo_nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["path", "imports"],
            "properties": {
              "path": { "type": "string" },
              "imports": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["from", "to", "kind"],
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "kind": { "enum": ["existing", "new", "removed"] }
            }
          }
        },
        "clusters": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["name", "paths"],
            "properties": {
              "name": { "type": "string" },
              "paths": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "reading_order": {
      "type": "object",
      "additionalProperties": true,
      "required": ["legs"],
      "properties": {
        "legs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["title", "read_together", "steps"],
            "properties": {
              "title": { "type": "string" },
              "read_together": { "type": "boolean" },
              "steps": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": true,
                  "required": ["path", "why", "queue_refs"],
                  "properties": {
                    "path": { "type": "string" },
                    "why": { "type": "string" },
                    "queue_refs": { "type": "array", "items": { "type": "string" } }
                  }
                }
              }
            }
          }
        }
      }
    },
    "coverage_evidence": {
      "type": "object",
      "additionalProperties": true,
      "required": ["status", "files"],
      "properties": {
        "status": { "enum": ["no_report", "report"] },
        "source_path": { "type": "string" },
        "postdates_head": { "type": "boolean" },
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["path", "changed_lines", "covered_lines", "classification", "hunks"],
            "properties": {
              "path": { "type": "string" },
              "changed_lines": { "type": "integer", "minimum": 0 },
              "covered_lines": { "type": "integer", "minimum": 0 },
              "classification": { "enum": ["covered", "uncovered", "partial"] },
              "hunks": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": true,
                  "required": ["hunk_header", "changed_lines", "covered_lines", "classification"],
                  "properties": {
                    "hunk_header": { "type": "string" },
                    "changed_lines": { "type": "integer", "minimum": 0 },
                    "covered_lines": { "type": "integer", "minimum": 0 },
                    "classification": { "enum": ["covered", "uncovered", "partial"] },
                    "uncovered_lines": { "type": "array", "maxItems": 50, "items": { "type": "integer", "minimum": 1 } },
                    "uncovered_truncated": { "type": "boolean" },
                    "covered_line_numbers": { "type": "array", "items": { "type": "integer", "minimum": 1 } }
                  }
                }
              }
            }
          }
        }
      }
    },
    "test_plan": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/testPlanItem"
      }
    },
    "skim_safe": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/skimSafeItem"
      }
    },
    "feedback_effects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/feedbackEffect"
      }
    },
    "generated_from": {
      "type": "object",
      "additionalProperties": true,
      "required": ["packet_path", "base_ref", "head_ref", "head_sha"],
      "properties": {
        "packet_path": { "type": "string" },
        "pr_surface_path": { "type": "string" },
        "base_ref": { "type": "string" },
        "base_sha": { "type": "string" },
        "head_ref": { "type": "string" },
        "head_sha": { "type": "string" },
        "human_review_config_signature": { "type": "string" }
      }
    }
  },
  "$defs": {
    "confidence": {
      "enum": ["high", "medium", "low", "unknown"]
    },
    "semanticChangeFacts": {
      "type": "object",
      "additionalProperties": true,
      "required": ["schema_changes", "api_changes", "test_weakening"],
      "properties": {
        "schema_changes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["path", "properties_added", "properties_removed", "required_added", "required_removed", "type_changes", "enum_changes"],
            "properties": {
              "path": { "type": "string" },
              "properties_added": { "type": "array", "items": { "type": "string" } },
              "properties_removed": { "type": "array", "items": { "type": "string" } },
              "required_added": { "type": "array", "items": { "type": "string" } },
              "required_removed": { "type": "array", "items": { "type": "string" } },
              "type_changes": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": true,
                  "required": ["field", "from", "to"],
                  "properties": {
                    "field": { "type": "string" },
                    "from": { "type": "string" },
                    "to": { "type": "string" }
                  }
                }
              },
              "enum_changes": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": true,
                  "required": ["field", "added", "removed"],
                  "properties": {
                    "field": { "type": "string" },
                    "added": { "type": "array", "items": { "type": "string" } },
                    "removed": { "type": "array", "items": { "type": "string" } }
                  }
                }
              }
            }
          }
        },
        "api_changes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["path", "exports_added", "exports_removed", "signatures_changed"],
            "properties": {
              "path": { "type": "string" },
              "exports_added": { "type": "array", "items": { "type": "string" } },
              "exports_removed": { "type": "array", "items": { "type": "string" } },
              "signatures_changed": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": true,
                  "required": ["name", "from", "to"],
                  "properties": {
                    "name": { "type": "string" },
                    "from": { "type": "string" },
                    "to": { "type": "string" }
                  }
                }
              }
            }
          }
        },
        "test_weakening": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["kind", "path", "detail"],
            "properties": {
              "kind": { "enum": ["deleted_test_file", "skipped_test", "removed_assertion", "regenerated_snapshot"] },
              "path": { "type": "string" },
              "detail": { "type": "string" }
            }
          }
        }
      }
    },
    "changeNarrative": {
      "type": "object",
      "additionalProperties": true,
      "required": ["source", "provider", "validated_at_head", "claims"],
      "properties": {
        "source": { "enum": ["provider", "fallback"] },
        "provider": { "enum": ["mock", "agent-file", "ai-sdk"] },
        "validated_at_head": { "type": "string" },
        "claims": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["id", "text", "trust", "anchors", "invalid_anchors"],
            "properties": {
              "id": { "type": "string" },
              "text": { "type": "string" },
              "trust": { "enum": ["verified", "claimed"] },
              "anchors": {
                "type": "array",
                "items": { "$ref": "#/$defs/evidenceRef" }
              },
              "invalid_anchors": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "severity": {
      "enum": ["low", "medium", "high", "critical", "unknown"]
    },
    "evidenceRef": {
      "type": "object",
      "additionalProperties": true,
      "required": ["kind", "confidence"],
      "properties": {
        "kind": {
          "enum": [
            "file",
            "diff",
            "test",
            "ci",
            "doc",
            "spec",
            "conversation",
            "command",
            "feedback",
            "agent_instruction",
            "url",
            "unknown"
          ]
        },
        "path": { "type": "string" },
        "line_start": { "type": "integer", "minimum": 1 },
        "line_end": { "type": "integer", "minimum": 1 },
        "sha": { "type": "string" },
        "url": { "type": "string" },
        "acai_id": { "type": "string" },
        "event_id": { "type": "string" },
        "test_name": { "type": "string" },
        "command": { "type": "string" },
        "excerpt_hash": { "type": "string" },
        "note": { "type": "string" },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "validation_status": {
          "enum": ["valid", "invalid", "not_checked", "unknown"]
        },
        "llm_proposed": { "type": "boolean" },
        "verified": { "type": "boolean" }
      }
    },
    "verdictReason": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "severity", "summary", "evidence"],
      "properties": {
        "id": { "type": "string" },
        "severity": { "$ref": "#/$defs/severity" },
        "summary": { "type": "string" },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidenceRef" }
        },
        "required_action": { "type": "string" }
      }
    },
    "reviewPlanItem": {
      "type": "object",
      "additionalProperties": true,
      "required": ["queue_item_id", "path", "estimated_minutes"],
      "properties": {
        "queue_item_id": { "type": "string" },
        "path": { "type": "string" },
        "estimated_minutes": { "type": "integer", "minimum": 1 },
        "reason": { "type": "string" }
      }
    },
    "reviewQueueItem": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "rank",
        "title",
        "path",
        "reason",
        "reviewer_action",
        "ranking_reasons",
        "evidence",
        "requirement_ids",
        "risk_ids",
        "confidence",
        "priority"
      ],
      "properties": {
        "id": { "type": "string" },
        "rank": { "type": "integer", "minimum": 1 },
        "title": { "type": "string" },
        "path": { "type": "string" },
        "old_path": { "type": "string" },
        "line_start": { "type": "integer", "minimum": 1 },
        "line_end": { "type": "integer", "minimum": 1 },
        "hunk_header": { "type": "string" },
        "anchor_side": { "enum": ["old", "new"] },
        "reason": { "type": "string" },
        "reviewer_action": { "type": "string" },
        "ranking_reasons": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidenceRef" }
        },
        "risk_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "requirement_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "confidence": { "$ref": "#/$defs/confidence" },
        "priority": {
          "enum": ["blocker", "high", "medium", "low"]
        },
        "estimated_review_effort": {
          "enum": ["quick", "moderate", "deep"]
        }
      }
    },
    "blocker": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "severity", "summary", "evidence", "required_action"],
      "properties": {
        "id": { "type": "string" },
        "severity": { "$ref": "#/$defs/severity" },
        "summary": { "type": "string" },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidenceRef" }
        },
        "required_action": { "type": "string" }
      }
    },
    "question": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "severity", "question", "reason", "evidence", "maps_to_risks", "maps_to_requirements"],
      "properties": {
        "id": { "type": "string" },
        "severity": {
          "enum": ["blocking", "clarifying", "optional"]
        },
        "question": { "type": "string" },
        "reason": { "type": "string" },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidenceRef" }
        },
        "maps_to_risks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "maps_to_requirements": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "suggestedComment": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "severity", "body", "evidence", "risk_ids", "requirement_ids", "confidence", "ready_to_post"],
      "properties": {
        "id": { "type": "string" },
        "severity": {
          "enum": ["blocking", "clarifying", "non_blocking"]
        },
        "path": { "type": "string" },
        "line_start": { "type": "integer", "minimum": 1 },
        "line_end": { "type": "integer", "minimum": 1 },
        "side": { "enum": ["old", "new"] },
        "body": { "type": "string", "maxLength": 2000 },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidenceRef" }
        },
        "risk_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "requirement_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "confidence": { "$ref": "#/$defs/confidence" },
        "ready_to_post": { "type": "boolean" }
      }
    },
    "trustAudit": {
      "type": "object",
      "additionalProperties": true,
      "required": ["verified_facts", "claimed_not_verified", "missing_evidence", "invalid_evidence", "confidence_summary"],
      "properties": {
        "verified_facts": {
          "type": "array",
          "items": { "$ref": "#/$defs/trustFact" }
        },
        "claimed_not_verified": {
          "type": "array",
          "items": { "$ref": "#/$defs/trustClaim" }
        },
        "missing_evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/missingEvidence" }
        },
        "invalid_evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/invalidEvidence" }
        },
        "confidence_summary": { "type": "string" }
      }
    },
    "trustFact": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "summary", "evidence"],
      "properties": {
        "id": { "type": "string" },
        "summary": { "type": "string" },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidenceRef" }
        }
      }
    },
    "trustClaim": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "claim", "status", "missing_evidence", "evidence"],
      "properties": {
        "id": { "type": "string" },
        "claim": { "type": "string" },
        "status": { "const": "unverified" },
        "missing_evidence": { "type": "string" },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidenceRef" }
        }
      }
    },
    "missingEvidence": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "summary", "evidence"],
      "properties": {
        "id": { "type": "string" },
        "summary": { "type": "string" },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidenceRef" }
        }
      }
    },
    "invalidEvidence": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "summary", "evidence"],
      "properties": {
        "id": { "type": "string" },
        "summary": { "type": "string" },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidenceRef" }
        }
      }
    },
    "testPlanItem": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "kind",
        "priority",
        "scenario",
        "expected_result",
        "maps_to_requirements",
        "maps_to_risks",
        "evidence_gap"
      ],
      "properties": {
        "id": { "type": "string" },
        "kind": { "enum": ["automatic", "manual"] },
        "priority": { "enum": ["required", "recommended", "optional"] },
        "suggested_file": { "type": "string" },
        "scenario": { "type": "string" },
        "expected_result": { "type": "string" },
        "command": { "type": "string" },
        "maps_to_requirements": {
          "type": "array",
          "items": { "type": "string" }
        },
        "maps_to_risks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidence_gap": { "type": "string" }
      }
    },
    "riskLensFinding": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "lens",
        "severity",
        "summary",
        "reviewer_action",
        "evidence",
        "suggested_tests",
        "suggested_comments",
        "risk_ids",
        "requirement_ids",
        "paths",
        "confidence"
      ],
      "properties": {
        "id": { "type": "string" },
        "lens": {
          "enum": [
            "api_contract",
            "security_privacy",
            "llm_trust_boundary",
            "test_evidence",
            "reviewer_ux",
            "cache_provenance",
            "supply_chain",
            "custom"
          ]
        },
        "severity": { "$ref": "#/$defs/severity" },
        "summary": { "type": "string" },
        "reviewer_action": { "type": "string" },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/evidenceRef" }
        },
        "suggested_tests": {
          "type": "array",
          "items": { "$ref": "#/$defs/testPlanItem" }
        },
        "suggested_comments": {
          "type": "array",
          "items": { "$ref": "#/$defs/suggestedComment" }
        },
        "risk_ids": {
          "type": "array",
          "items": { "type": "string" }
        },
        "requirement_ids": {
          "type": "array",
