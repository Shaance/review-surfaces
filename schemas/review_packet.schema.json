{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://review-surfaces.local/schemas/review_packet.schema.v1.json",
  "title": "review-surfaces review packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "manifest",
    "intent",
    "evaluation",
    "architecture",
    "methodology",
    "risks"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "review-surfaces.packet.v1"
    },
    "manifest": {
      "$ref": "#/$defs/RunManifest"
    },
    "intent": {
      "$ref": "#/$defs/Intent"
    },
    "evaluation": {
      "$ref": "#/$defs/Evaluation"
    },
    "architecture": {
      "$ref": "#/$defs/Architecture"
    },
    "methodology": {
      "$ref": "#/$defs/Methodology"
    },
    "risks": {
      "$ref": "#/$defs/Risks"
    },
    "dogfood": {
      "$ref": "#/$defs/Dogfood"
    },
    "agent_handoff": {
      "$ref": "#/$defs/AgentHandoff"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "manifest": {
            "properties": {
              "run_mode": {
                "const": "dogfood"
              }
            },
            "required": [
              "run_mode"
            ]
          }
        },
        "required": [
          "manifest"
        ]
      },
      "then": {
        "required": [
          "dogfood",
          "agent_handoff"
        ]
      }
    }
  ],
  "$defs": {
    "RunManifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool_version",
        "created_at",
        "repo",
        "base_ref",
        "head_ref",
        "head_sha",
        "uncommitted_files",
        "run_mode"
      ],
      "properties": {
        "tool_version": {
          "type": "string"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "repo": {
          "type": "string"
        },
        "base_ref": {
          "type": "string"
        },
        "head_ref": {
          "type": "string"
        },
        "base_sha": {
          "type": "string"
        },
        "head_sha": {
          "type": "string"
        },
        "uncommitted_files": {
          "type": "integer",
          "minimum": 0
        },
        "run_mode": {
          "type": "string",
          "enum": [
            "local",
            "dogfood",
            "ci",
            "provider",
            "unknown"
          ]
        },
        "milestone": {
          "type": "string"
        },
        "iteration_id": {
          "type": "string"
        },
        "previous_packet_path": {
          "type": "string"
        },
        "input_hashes": {
          "type": "array",
          "maxItems": 100000,
          "items": {
            "$ref": "#/$defs/InputHash"
          }
        },
        "signature": {
          "type": "string"
        },
        "artifact_signatures": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "coverage": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "source_path",
            "algorithm",
            "hash",
            "postdates_head"
          ],
          "properties": {
            "source_path": {
              "type": "string"
            },
            "algorithm": {
              "const": "sha256"
            },
            "hash": {
              "type": "string"
            },
            "head_committed_at": {
              "type": "string"
            },
            "report_modified_at": {
              "type": "string"
            },
            "postdates_head": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "InputHash": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "algorithm",
        "hash"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "algorithm": {
          "type": "string"
        },
        "hash": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        }
      }
    },
    "EvidenceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "confidence"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "file",
            "diff",
            "test",
            "ci",
            "doc",
            "spec",
            "conversation",
            "command",
            "feedback",
            "agent_instruction",
            "url",
            "unknown"
          ]
        },
        "path": {
          "type": "string"
        },
        "line_start": {
          "type": "integer",
          "minimum": 1
        },
        "line_end": {
          "type": "integer",
          "minimum": 1
        },
        "sha": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "acai_id": {
          "type": "string",
          "pattern": "^[a-z0-9_-]+\\.[A-Z0-9_]+\\.[0-9]+(-[0-9]+)?$"
        },
        "event_id": {
          "type": "string"
        },
        "test_name": {
          "type": "string"
        },
        "command": {
          "type": "string",
          "maxLength": 20000
        },
        "excerpt_hash": {
          "type": "string"
        },
        "note": {
          "type": "string",
          "maxLength": 20000
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low",
            "unknown"
          ]
        },
        "validation_status": {
          "type": "string",
          "enum": [
            "valid",
            "invalid",
            "not_checked",
            "unknown"
          ]
        },
        "llm_proposed": {
          "type": "boolean"
        },
        "verified": {
          "type": "boolean"
        }
      }
    },
    "SourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "ref"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "spec",
            "doc",
            "file",
            "conversation",
            "feedback",
            "unknown"
          ]
        },
        "ref": {
          "type": "string"
        },
        "title": {
          "type": "string",
          "maxLength": 20000
        },
        "evidence": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "$ref": "#/$defs/EvidenceRef"
          }
        }
      }
    },
    "Requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "requirement",
        "confidence"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "acai_id": {
          "type": "string"
        },
        "title": {
          "type": "string",
          "maxLength": 20000
        },
        "requirement": {
          "type": "string",
          "maxLength": 20000
        },
        "source_refs": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "$ref": "#/$defs/SourceRef"
          }
        },
        "constraints": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "string",
            "maxLength": 20000
          }
        },
        "assumptions": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "string",
            "maxLength": 20000
          }
        },
        "open_questions": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "string",
            "maxLength": 20000
          }
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low",
            "unknown"
          ]
        },
        "llm_derived": {
          "type": "boolean"
        }
      }
    },
    "Intent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "spec_mode",
        "requirements"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "maxLength": 20000
        },
        "spec_mode": {
          "enum": ["acai", "none"]
        },
        "requirements": {
          "type": "array",
          "maxItems": 5000,
          "items": {
            "$ref": "#/$defs/Requirement"
          }
        },
        "constraints": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "string",
            "maxLength": 20000
          }
        },
        "non_goals": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "string",
            "maxLength": 20000
          }
        },
        "assumptions": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "string",
            "maxLength": 20000
          }
        },
        "open_questions": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "string",
            "maxLength": 20000
          }
        },
        "claimed_candidates": {
          "type": "array",
          "maxItems": 5000,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "statement", "anchors", "confidence", "trust"],
            "properties": {
              "id": { "type": "string" },
              "statement": { "type": "string", "maxLength": 20000 },
              "anchors": {
                "type": "array",
                "maxItems": 1000,
                "items": { "type": "string", "maxLength": 20000 }
              },
              "confidence": { "enum": ["medium", "low"] },
              "trust": { "const": "claimed" }
            }
          }
        },
        "sources": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "$ref": "#/$defs/SourceRef"
          }
        }
      }
    },
    "RequirementResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirement_id",
        "status",
        "summary"
      ],
      "properties": {
        "requirement_id": {
          "type": "string"
        },
        "acai_id": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "satisfied",
            "partial",
            "missing",
            "unknown",
            "overreach",
            "invalid_evidence"
          ]
        },
        "summary": {
          "type": "string",
          "maxLength": 20000
        },
        "partial_reason": {
          "type": "string",
          "enum": [
            "impl_no_test",
            "test_no_impl",
            "impl_broad_no_exact_test",
            "exact_impl_broad_test",
            "broad_area_only",
            "other"
          ]
        },
        "evidence": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "$ref": "#/$defs/EvidenceRef"
          }
        },
        "missing_evidence": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "$ref": "#/$defs/EvidenceRef"
          }
        },
        "review_focus": {
          "type": "string",
          "maxLength": 20000
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low",
            "unknown"
          ]
        }
      }
    },
    "Evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "results"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "maxLength": 20000
        },
        "results": {
          "type": "array",
          "maxItems": 5000,
          "items": {
            "$ref": "#/$defs/RequirementResult"
          }
        },
        "overreach": {
          "type": "array",
          "maxItems": 5000,
          "items": {
            "$ref": "#/$defs/RequirementResult"
          }
        },
        "acai_coverage": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "SubsystemCard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "summary",
        "files"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string",
          "maxLength": 20000
        },
        "summary": {
          "type": "string",
          "maxLength": 20000
        },
        "files": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "string",
            "maxLength": 20000
          }
        },
        "responsibilities": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "string",
            "maxLength": 20000
          }
        },
        "interactions": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "string",
            "maxLength": 20000
          }
        },
        "tests": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "string",
            "maxLength": 20000
          }
        },
        "risks": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "string",
            "maxLength": 20000
          }
        },
        "evidence": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "$ref": "#/$defs/EvidenceRef"
          }
        }
      }
    },
    "Architecture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "diagram_validation"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "maxLength": 20000
        },
        "diagrams": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "string",
            "maxLength": 20000
          }
        },
        "diagram_validation": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "$ref": "#/$defs/DiagramValidation"
          }
        },
        "subsystems": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "$ref": "#/$defs/SubsystemCard"
          }
        },
        "open_questions": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "string",
            "maxLength": 20000
          }
        }
      }
    },
    "DiagramValidation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "status",
        "diagram_type",
        "errors",
        "warnings",
        "evidence"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "valid",
            "invalid"
          ]
        },
        "diagram_type": {
          "type": "string",
          "enum": [
            "flowchart",
            "sequenceDiagram",
            "unknown"
          ]
        },
        "errors": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "string",
            "maxLength": 20000
          }
        },
        "warnings": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "string",
            "maxLength": 20000
          }
        },
        "evidence": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "$ref": "#/$defs/EvidenceRef"
          }
        }
      }
    },
    "Methodology": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "missing_logs",
        "claims_without_evidence",
        "verified_claims",
        "quality_flags"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "maxLength": 20000
        },
        "missing_logs": {
          "type": "boolean"
        },
        "considered": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "string",
            "maxLength": 20000
          }
        },
        "research": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "string",
            "maxLength": 20000
          }
        },
        "decisions": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "string",
            "maxLength": 20000
          }
        },
        "unchallenged_assumptions": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "string",
            "maxLength": 20000
          }
        },
        "skipped_checks": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "string",
            "maxLength": 20000
          }
        },
        "claims_without_evidence": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "string",
            "maxLength": 20000
          }
        },
        "verified_claims": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "string",
            "maxLength": 20000
          }
        },
        "quality_flags": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "string",
            "maxLength": 20000
          }
        },
        "evidence": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "$ref": "#/$defs/EvidenceRef"
          }
        }
      }
    },
    "RiskItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "category",
        "severity",
        "summary"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "enum": [
            "correctness",
            "security",
            "privacy",
            "maintainability",
            "architecture",
            "testing",
            "workflow",
            "release",
            "performance",
            "unknown"
          ]
        },
        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical",
            "unknown"
          ]
        },
        "likelihood": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "unknown"
          ]
        },
        "detectability": {
          "type": "string",
          "enum": [
            "easy",
            "moderate",
            "hard",
            "unknown"
          ]
        },
        "summary": {
          "type": "string",
          "maxLength": 20000
        },
        "impact": {
          "type": "string",
          "maxLength": 20000
        },
        "evidence": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "$ref": "#/$defs/EvidenceRef"
          }
        },
        "suggested_checks": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "string",
            "maxLength": 20000
          }
        },
        "manual_review": {
          "type": "boolean"
        }
      }
    },
    "TestEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "summary"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "direct",
            "indirect",
            "claimed",
            "missing",
            "unknown"
          ]
        },
        "summary": {
          "type": "string",
          "maxLength": 20000
        },
        "requirement_ids": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "string",
            "maxLength": 20000
          }
        },
        "evidence": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "$ref": "#/$defs/EvidenceRef"
          }
        }
      }
    },
    "TestGap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "summary"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "requirement_id": {
          "type": "string"
        },
        "acai_id": {
          "type": "string"
        },
        "summary": {
          "type": "string",
          "maxLength": 20000
        },
        "suggested_test": {
          "type": "string",
          "maxLength": 20000
        },
        "manual_check": {
          "type": "string",
          "maxLength": 20000
        },
        "evidence": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "$ref": "#/$defs/EvidenceRef"
          }
        }
      }
    },
    "Risks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "items",
        "missing_automatic_tests",
        "missing_manual_checks"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "maxLength": 20000
        },
        "items": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "$ref": "#/$defs/RiskItem"
          }
        },
        "test_evidence": {
          "type": "array",
          "maxItems": 100000,
          "items": {
            "$ref": "#/$defs/TestEvidence"
          }
        },
        "test_gaps": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "$ref": "#/$defs/TestGap"
          }
        },
        "missing_automatic_tests": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "$ref": "#/$defs/MissingAutomaticTest"
          }
        },
        "missing_manual_checks": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "$ref": "#/$defs/MissingManualCheck"
          }
        },
        "review_focus": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "type": "string",
            "maxLength": 20000
          }
        }
      }
    },
    "MissingAutomaticTest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "summary",
        "suggested_test"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "requirement_id": {
          "type": "string"
        },
        "acai_id": {
          "type": "string"
        },
        "summary": {
          "type": "string",
          "maxLength": 20000
        },
        "suggested_test": {
          "type": "string",
          "maxLength": 20000
        },
        "evidence": {
          "type": "array",
          "maxItems": 1000,
          "items": {
            "$ref": "#/$defs/EvidenceRef"
          }
        }
      }
    },
    "MissingManualCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "summary",
        "manual_check"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "requirement_id": {
