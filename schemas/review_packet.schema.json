{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://review-surfaces.local/schemas/review_packet.schema.v1.json",
  "title": "review-surfaces review packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "manifest",
    "intent",
    "evaluation",
    "architecture",
    "methodology",
    "risks"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "review-surfaces.packet.v1"
    },
    "manifest": {
      "$ref": "#/$defs/RunManifest"
    },
    "intent": {
      "$ref": "#/$defs/Intent"
    },
    "evaluation": {
      "$ref": "#/$defs/Evaluation"
    },
    "architecture": {
      "$ref": "#/$defs/Architecture"
    },
    "methodology": {
      "$ref": "#/$defs/Methodology"
    },
    "risks": {
      "$ref": "#/$defs/Risks"
    },
    "dogfood": {
      "$ref": "#/$defs/Dogfood"
    },
    "agent_handoff": {
      "$ref": "#/$defs/AgentHandoff"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "manifest": {
            "properties": {
              "run_mode": {
                "const": "dogfood"
              }
            },
            "required": [
              "run_mode"
            ]
          }
        },
        "required": [
          "manifest"
        ]
      },
      "then": {
        "required": [
          "dogfood",
          "agent_handoff"
        ]
      }
    }
  ],
  "$defs": {
    "RunManifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool_version",
        "created_at",
        "repo",
        "base_ref",
        "head_ref",
        "head_sha",
        "run_mode"
      ],
      "properties": {
        "tool_version": {
          "type": "string"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "repo": {
          "type": "string"
        },
        "base_ref": {
          "type": "string"
        },
        "head_ref": {
          "type": "string"
        },
        "base_sha": {
          "type": "string"
        },
        "head_sha": {
          "type": "string"
        },
        "run_mode": {
          "type": "string",
          "enum": [
            "local",
            "dogfood",
            "ci",
            "provider",
            "unknown"
          ]
        },
        "milestone": {
          "type": "string"
        },
        "iteration_id": {
          "type": "string"
        },
        "previous_packet_path": {
          "type": "string"
        },
        "input_hashes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/InputHash"
          }
        }
      }
    },
    "InputHash": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "algorithm",
        "hash"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "algorithm": {
          "type": "string"
        },
        "hash": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        }
      }
    },
    "EvidenceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "confidence"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "file",
            "diff",
            "test",
            "ci",
            "doc",
            "spec",
            "conversation",
            "command",
            "feedback",
            "agent_instruction",
            "url",
            "unknown"
          ]
        },
        "path": {
          "type": "string"
        },
        "line_start": {
          "type": "integer",
          "minimum": 1
        },
        "line_end": {
          "type": "integer",
          "minimum": 1
        },
        "sha": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "acai_id": {
          "type": "string",
          "pattern": "^[a-z0-9_-]+\\.[A-Z0-9_]+\\.[0-9]+(-[0-9]+)?$"
        },
        "event_id": {
          "type": "string"
        },
        "test_name": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "excerpt_hash": {
          "type": "string"
        },
        "note": {
          "type": "string"
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low",
            "unknown"
          ]
        },
        "validation_status": {
          "type": "string",
          "enum": [
            "valid",
            "invalid",
            "not_checked",
            "unknown"
          ]
        }
      }
    },
    "SourceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "ref"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "spec",
            "doc",
            "file",
            "conversation",
            "feedback",
            "unknown"
          ]
        },
        "ref": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EvidenceRef"
          }
        }
      }
    },
    "Requirement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "requirement",
        "confidence"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "acai_id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "requirement": {
          "type": "string"
        },
        "source_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SourceRef"
          }
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "open_questions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low",
            "unknown"
          ]
        }
      }
    },
    "Intent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "requirements"
      ],
      "properties": {
        "summary": {
          "type": "string"
        },
        "requirements": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Requirement"
          }
        },
        "constraints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "non_goals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "open_questions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sources": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SourceRef"
          }
        }
      }
    },
    "RequirementResult": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirement_id",
        "status",
        "summary"
      ],
      "properties": {
        "requirement_id": {
          "type": "string"
        },
        "acai_id": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "satisfied",
            "partial",
            "missing",
            "unknown",
            "overreach",
            "invalid_evidence"
          ]
        },
        "summary": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EvidenceRef"
          }
        },
        "missing_evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EvidenceRef"
          }
        },
        "review_focus": {
          "type": "string"
        },
        "confidence": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low",
            "unknown"
          ]
        }
      }
    },
    "Evaluation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "results"
      ],
      "properties": {
        "summary": {
          "type": "string"
        },
        "results": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/RequirementResult"
          }
        },
        "overreach": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/RequirementResult"
          }
        },
        "acai_coverage": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "SubsystemCard": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "summary",
        "files"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "responsibilities": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "interactions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tests": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "risks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EvidenceRef"
          }
        }
      }
    },
    "Architecture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary"
      ],
      "properties": {
        "summary": {
          "type": "string"
        },
        "diagrams": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "subsystems": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SubsystemCard"
          }
        },
        "open_questions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "Methodology": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "missing_logs"
      ],
      "properties": {
        "summary": {
          "type": "string"
        },
        "missing_logs": {
          "type": "boolean"
        },
        "considered": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "research": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "decisions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "unchallenged_assumptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "skipped_checks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "claims_without_evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EvidenceRef"
          }
        }
      }
    },
    "RiskItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "category",
        "severity",
        "summary"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "enum": [
            "correctness",
            "security",
            "privacy",
            "maintainability",
            "architecture",
            "testing",
            "workflow",
            "release",
            "performance",
            "unknown"
          ]
        },
        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical",
            "unknown"
          ]
        },
        "likelihood": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "unknown"
          ]
        },
        "detectability": {
          "type": "string",
          "enum": [
            "easy",
            "moderate",
            "hard",
            "unknown"
          ]
        },
        "summary": {
          "type": "string"
        },
        "impact": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EvidenceRef"
          }
        },
        "suggested_checks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "manual_review": {
          "type": "boolean"
        }
      }
    },
    "TestEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "summary"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "direct",
            "indirect",
            "claimed",
            "missing",
            "unknown"
          ]
        },
        "summary": {
          "type": "string"
        },
        "requirement_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EvidenceRef"
          }
        }
      }
    },
    "TestGap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "summary"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "requirement_id": {
          "type": "string"
        },
        "acai_id": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "suggested_test": {
          "type": "string"
        },
        "manual_check": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EvidenceRef"
          }
        }
      }
    },
    "Risks": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "items"
      ],
      "properties": {
        "summary": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/RiskItem"
          }
        },
        "test_evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TestEvidence"
          }
        },
        "test_gaps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/TestGap"
          }
        },
        "review_focus": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "RemediationTask": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "description"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "code",
            "test",
            "schema",
            "doc",
            "spec",
            "skill",
            "feedback",
            "defer"
          ]
        },
        "description": {
          "type": "string"
        },
        "acai_id": {
          "type": "string"
        },
        "target_milestone": {
          "type": "string"
        }
      }
    },
    "DogfoodFinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "category",
        "severity",
        "finding"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "category": {
          "type": "string",
          "enum": [
            "usability",
            "review_value",
            "evidence_quality",
            "agent_workflow",
            "schema",
            "diagram_quality",
            "test_gap",
            "performance",
            "unknown"
          ]
        },
        "severity": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high",
            "critical",
            "unknown"
          ]
        },
        "packet_section": {
          "type": "string"
        },
        "finding": {
          "type": "string"
        },
        "impact": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/EvidenceRef"
          }
        },
        "remediation": {
          "$ref": "#/$defs/RemediationTask"
        }
      }
    },
    "Dogfood": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "milestone",
        "summary",
        "findings"
      ],
      "properties": {
        "milestone": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "helped_agent": {
          "type": "string",
          "enum": [
            "yes",
            "partially",
            "no",
            "unknown"
          ]
        },
        "helped_reviewer": {
          "type": "string",
          "enum": [
            "yes",
            "partially",
            "no",
            "unknown"
          ]
        },
        "previous_packet_path": {
          "type": "string"
        },
        "findings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/DogfoodFinding"
          }
        },
        "remediation_tasks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/RemediationTask"
          }
        },
        "deferrals": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "AgentHandoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "next_tasks"
      ],
      "properties": {
        "summary": {
          "type": "string"
        },
        "current_milestone": {
          "type": "string"
        },
        "relevant_acids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "commands_to_run": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "next_tasks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "open_risks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "artifact_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
