{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://review-surfaces.local/schemas/pr_review_surface.schema.v1.json",
  "title": "review-surfaces PR review surface",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "mode", "spec_mode", "status", "scope", "coverage", "risks", "llm"],
  "properties": {
    "schema_version": {
      "const": "review-surfaces.pr_surface.v1"
    },
    "mode": {
      "const": "pr"
    },
    "spec_mode": {
      "enum": ["acai", "none"]
    },
    "status": {
      "enum": ["ready", "blocked"]
    },
    "blocked_reason": {
      "enum": ["llm_unavailable", "llm_failed", "privacy_block", "baseline_unavailable", "no_diff", "invalid_llm_output"]
    },
    "scope": {
      "type": "object",
      "additionalProperties": true,
      "required": ["base_ref", "head_ref", "head_sha", "diff_source", "changed_files", "affected_areas", "affected_requirements", "out_of_scope_changed_files"],
      "properties": {
        "base_ref": { "type": "string" },
        "head_ref": { "type": "string" },
        "base_sha": { "type": "string" },
        "head_sha": { "type": "string" },
        "diff_source": { "enum": ["range", "working_tree_fallback"] },
        "changed_files": { "type": "array" },
        "affected_areas": { "type": "array" },
        "affected_requirements": { "type": "array" },
        "out_of_scope_changed_files": { "type": "array" }
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": true,
      "required": ["base_available", "summary", "in_scope_count", "deltas", "counts"],
      "properties": {
        "base_available": { "type": "boolean" },
        "summary": { "type": "string" },
        "in_scope_count": { "type": "integer", "minimum": 0 },
        "deltas": { "type": "array" },
        "counts": { "type": "object" }
      }
    },
    "risks": {
      "type": "object",
      "additionalProperties": true,
      "required": ["summary", "candidates"],
      "properties": {
        "summary": { "type": "string" },
        "candidates": { "type": "array" }
      }
    },
    "conversation_analysis": {
      "$ref": "#/$defs/conversationAnalysis"
    },
    "review_insights": {
      "type": "array",
      "maxItems": 3,
      "items": { "$ref": "#/$defs/reviewerInsight" }
    },
    "diagram": {
      "type": "object",
      "additionalProperties": true,
      "required": ["path", "status", "body", "warnings"],
      "properties": {
        "path": { "type": "string" },
        "status": { "enum": ["valid", "invalid"] },
        "body": { "type": "string" },
        "warnings": { "type": "array", "items": { "type": "string" } }
      }
    },
    "narrative": {
      "type": "object",
      "additionalProperties": true,
      "required": ["summary", "what_changed", "why_it_matters", "review_first", "risk_narratives"],
      "properties": {
        "summary": { "type": "string", "maxLength": 1000 },
        "what_changed": {
          "type": "array",
          "maxItems": 3,
          "items": { "$ref": "#/$defs/anchoredNarrativeItem" }
        },
        "why_it_matters": {
          "type": "array",
          "maxItems": 3,
          "items": { "$ref": "#/$defs/anchoredNarrativeItem" }
        },
        "review_first": {
          "type": "array",
          "maxItems": 5,
          "items": { "$ref": "#/$defs/anchoredNarrativeItem" }
        },
        "risk_narratives": {
          "type": "array",
          "maxItems": 8,
          "items": { "$ref": "#/$defs/anchoredRiskNarrative" }
        }
      }
    },
    "llm": {
      "type": "object",
      "additionalProperties": true,
      "required": ["required", "provider", "status"],
      "properties": {
        "required": { "const": true },
        "provider": { "enum": ["mock", "ai-sdk", "agent-file"] },
        "model": { "type": "string" },
        "status": { "enum": ["applied", "blocked", "failed"] },
        "prompt_hash": { "type": "string" },
        "output_hash": { "type": "string" },
        "validation_errors": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "$defs": {
    "confidence": {
      "enum": ["high", "medium", "low", "unknown"]
    },
    "severity": {
      "enum": ["low", "medium", "high", "critical", "unknown"]
    },
    "conversationAnalysisItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "event_ids"],
      "properties": {
        "text": { "type": "string", "minLength": 1, "maxLength": 500 },
        "event_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 6,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 180 }
        }
      }
    },
    "conversationAnalysisItems": {
      "type": "array",
      "maxItems": 12,
      "items": { "$ref": "#/$defs/conversationAnalysisItem" }
    },
    "conversationAnalysis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "provider",
        "summary",
        "intent",
        "refinements",
        "decisions",
        "constraints",
        "non_goals",
        "rejected_alternatives",
        "claims",
        "validation_claims",
        "known_gaps",
        "quality_flags"
      ],
      "properties": {
        "status": { "enum": ["analyzed", "not_assessed", "degraded"] },
        "provider": { "enum": ["mock", "ai-sdk", "agent-file"] },
        "summary": { "type": "string", "minLength": 1, "maxLength": 900 },
        "intent": { "$ref": "#/$defs/conversationAnalysisItems" },
        "refinements": { "$ref": "#/$defs/conversationAnalysisItems" },
        "decisions": { "$ref": "#/$defs/conversationAnalysisItems" },
        "constraints": { "$ref": "#/$defs/conversationAnalysisItems" },
        "non_goals": { "$ref": "#/$defs/conversationAnalysisItems" },
        "rejected_alternatives": { "$ref": "#/$defs/conversationAnalysisItems" },
        "claims": { "$ref": "#/$defs/conversationAnalysisItems" },
        "validation_claims": { "$ref": "#/$defs/conversationAnalysisItems" },
        "known_gaps": { "$ref": "#/$defs/conversationAnalysisItems" },
        "quality_flags": {
          "type": "array",
          "maxItems": 20,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 100 }
        }
      }
    },
    "insightStringArray": {
      "type": "array",
      "maxItems": 12,
      "uniqueItems": true,
      "items": { "type": "string", "minLength": 1, "maxLength": 300 }
    },
    "reviewerInsight": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "category",
        "title",
        "summary",
        "why_it_matters",
        "reviewer_action",
        "priority",
        "evidence_state",
        "basis",
        "conversation_event_ids",
        "paths",
        "requirement_ids",
        "risk_ids",
        "command_ids",
        "evidence"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 80 },
        "category": {
          "enum": [
            "intent_mismatch",
            "scope_surprise",
            "superseded_decision",
            "validation_gap",
            "test_weakening",
            "unresolved_assumption",
            "intentional_change"
          ]
        },
        "title": { "type": "string", "minLength": 1, "maxLength": 180 },
        "summary": { "type": "string", "minLength": 1, "maxLength": 700 },
        "why_it_matters": { "type": "string", "minLength": 1, "maxLength": 700 },
        "reviewer_action": { "type": "string", "minLength": 1, "maxLength": 700 },
        "priority": { "$ref": "#/$defs/severity" },
        "evidence_state": { "enum": ["supported", "contradicted", "unverified"] },
        "basis": { "enum": ["validated_anchors", "ai_reconciliation"] },
        "conversation_event_ids": {
          "type": "array",
          "minItems": 1,
          "maxItems": 12,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 300 }
        },
        "paths": { "$ref": "#/$defs/insightStringArray" },
        "requirement_ids": { "$ref": "#/$defs/insightStringArray" },
        "risk_ids": { "$ref": "#/$defs/insightStringArray" },
        "command_ids": { "$ref": "#/$defs/insightStringArray" },
        "evidence": {
          "type": "array",
          "minItems": 1,
          "maxItems": 18,
          "items": { "$ref": "#/$defs/evidenceRef" }
        }
      }
    },
    "evidenceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "confidence"],
      "properties": {
        "kind": {
          "enum": [
            "file",
            "diff",
            "test",
            "ci",
            "doc",
            "spec",
            "conversation",
            "command",
            "feedback",
            "agent_instruction",
            "url",
            "unknown"
          ]
        },
        "path": { "type": "string" },
        "line_start": { "type": "integer", "minimum": 1 },
        "line_end": { "type": "integer", "minimum": 1 },
        "sha": { "type": "string" },
        "url": { "type": "string" },
        "acai_id": { "type": "string" },
        "event_id": { "type": "string" },
        "test_name": { "type": "string" },
        "command": { "type": "string" },
        "excerpt_hash": { "type": "string" },
        "note": { "type": "string" },
        "confidence": { "$ref": "#/$defs/confidence" },
        "validation_status": { "enum": ["valid", "invalid", "not_checked", "unknown"] },
        "llm_proposed": { "type": "boolean" },
        "verified": { "type": "boolean" }
      }
    },
    "anchor": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300
    },
    "anchoredNarrativeItem": {
      "type": "object",
      "additionalProperties": true,
      "required": ["text"],
      "properties": {
        "text": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "paths": {
          "type": "array",
          "maxItems": 10,
          "items": { "$ref": "#/$defs/anchor" }
        },
        "requirement_ids": {
          "type": "array",
          "maxItems": 10,
          "items": { "$ref": "#/$defs/anchor" }
        },
        "risk_ids": {
          "type": "array",
          "maxItems": 10,
          "items": { "$ref": "#/$defs/anchor" }
        }
      }
    },
    "anchoredRiskNarrative": {
      "type": "object",
      "additionalProperties": true,
      "required": ["risk_id", "text"],
      "properties": {
        "risk_id": { "$ref": "#/$defs/anchor" },
        "text": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "suggested_checks": {
          "type": "array",
          "maxItems": 6,
          "items": { "type": "string", "minLength": 1, "maxLength": 500 }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "ready" } },
        "required": ["status"]
      },
      "then": {
        "required": ["narrative"]
      }
    },
    {
      "if": {
        "properties": { "status": { "const": "blocked" } },
        "required": ["status"]
      },
      "then": {
        "required": ["blocked_reason"]
      }
    }
  ]
}
