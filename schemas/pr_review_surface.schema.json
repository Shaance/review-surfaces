{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://review-surfaces.local/schemas/pr_review_surface.schema.v1.json",
  "title": "review-surfaces PR review surface",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "mode", "status", "scope", "coverage", "risks"],
  "properties": {
    "schema_version": { "const": "review-surfaces.pr_surface.v1" },
    "mode": { "const": "pr" },
    "status": { "enum": ["ready", "blocked"] },
    "blocked_reason": { "const": "no_diff" },
    "change_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "source", "redaction_blocked"],
      "properties": {
        "title": { "type": "string", "minLength": 1, "maxLength": 300 },
        "description": { "type": "string", "maxLength": 6000 },
        "source": { "enum": ["github", "cli"] },
        "redaction_blocked": { "type": "boolean" }
      }
    },
    "scope": { "$ref": "#/$defs/prScope" },
    "coverage": { "$ref": "#/$defs/prCoverage" },
    "risks": { "$ref": "#/$defs/prRisks" },
    "diagram": { "$ref": "#/$defs/prDiagram" }
  },
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "blocked" } },
        "required": ["status"]
      },
      "then": { "required": ["blocked_reason"] }
    }
  ],
  "$defs": {
    "evidenceRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "confidence"],
      "properties": {
        "kind": {
          "enum": [
            "file",
            "diff",
            "test",
            "ci",
            "doc",
            "spec",
            "conversation",
            "command",
            "feedback",
            "agent_instruction",
            "url",
            "unknown"
          ]
        },
        "path": { "type": "string", "maxLength": 4096 },
        "line_start": { "type": "integer", "minimum": 1 },
        "line_end": { "type": "integer", "minimum": 1 },
        "sha": { "type": "string", "maxLength": 256 },
        "url": { "type": "string", "maxLength": 8192 },
        "acai_id": { "type": "string", "maxLength": 500 },
        "event_id": { "type": "string", "maxLength": 500 },
        "test_name": { "type": "string", "maxLength": 2000 },
        "command": { "type": "string", "maxLength": 12000 },
        "excerpt_hash": { "type": "string", "maxLength": 256 },
        "note": { "type": "string", "maxLength": 6000 },
        "confidence": { "enum": ["high", "medium", "low", "unknown"] },
        "validation_status": { "enum": ["valid", "invalid", "not_checked", "unknown"] },
        "llm_proposed": { "type": "boolean" },
        "verified": { "type": "boolean" }
      }
    },
    "scopeReason": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule", "confidence"],
      "properties": {
        "rule": {
          "enum": [
            "exact_acid_in_diff",
            "spec_block_changed",
            "changed_test_exact_acid",
            "changed_path_requirement_group",
            "changed_test_group"
          ]
        },
        "confidence": { "enum": ["high", "medium", "low"] },
        "path": { "type": "string", "maxLength": 4096 },
        "line_start": { "type": "integer", "minimum": 1 },
        "line_end": { "type": "integer", "minimum": 1 },
        "note": { "type": "string", "maxLength": 6000 }
      }
    },
    "changedFile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "status", "areas", "role"],
      "properties": {
        "path": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "old_path": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "status": { "type": "string", "minLength": 1, "maxLength": 100 },
        "areas": {
          "type": "array",
          "maxItems": 10000,
          "items": { "type": "string", "minLength": 1, "maxLength": 500 }
        },
        "role": {
          "enum": ["implementation", "test", "spec", "doc", "config", "ci", "generated", "unknown"]
        },
        "added_lines": { "type": "integer", "minimum": 0 },
        "deleted_lines": { "type": "integer", "minimum": 0 }
      }
    },
    "affectedArea": {
      "type": "object",
      "additionalProperties": false,
      "required": ["group_key", "area_ids", "name", "changed_files"],
      "properties": {
        "group_key": { "type": "string", "minLength": 1, "maxLength": 500 },
        "area_ids": {
          "type": "array",
          "maxItems": 10000,
          "items": { "type": "string", "minLength": 1, "maxLength": 500 }
        },
        "name": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "changed_files": {
          "type": "array",
          "maxItems": 100000,
          "items": { "type": "string", "minLength": 1, "maxLength": 4096 }
        }
      }
    },
    "affectedRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requirement_id", "reasons"],
      "properties": {
        "requirement_id": { "type": "string", "minLength": 1, "maxLength": 500 },
        "acai_id": { "type": "string", "minLength": 1, "maxLength": 500 },
        "title": { "type": "string", "maxLength": 2000 },
        "group_key": { "type": "string", "minLength": 1, "maxLength": 500 },
        "reasons": {
          "type": "array",
          "maxItems": 10000,
          "items": { "$ref": "#/$defs/scopeReason" }
        }
      }
    },
    "outOfScopeChangedFile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "status", "reason"],
      "properties": {
        "path": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "status": { "type": "string", "minLength": 1, "maxLength": 100 },
        "reason": { "enum": ["unmapped", "ignored", "generated"] }
      }
    },
    "prScope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "base_ref",
        "head_ref",
        "head_sha",
        "diff_source",
        "changed_files",
        "affected_areas",
        "affected_requirements",
        "out_of_scope_changed_files"
      ],
      "properties": {
        "base_ref": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "head_ref": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "base_sha": { "type": "string", "maxLength": 256 },
        "head_sha": { "type": "string", "minLength": 1, "maxLength": 256 },
        "diff_source": { "enum": ["range", "working_tree_fallback"] },
        "changed_files": {
          "type": "array",
          "maxItems": 100000,
          "items": { "$ref": "#/$defs/changedFile" }
        },
        "affected_areas": {
          "type": "array",
          "maxItems": 10000,
          "items": { "$ref": "#/$defs/affectedArea" }
        },
        "affected_requirements": {
          "type": "array",
          "maxItems": 100000,
          "items": { "$ref": "#/$defs/affectedRequirement" }
        },
        "out_of_scope_changed_files": {
          "type": "array",
          "maxItems": 100000,
          "items": { "$ref": "#/$defs/outOfScopeChangedFile" }
        }
      }
    },
    "coverageDelta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requirement_id",
        "base_status",
        "head_status",
        "delta",
        "reasons",
        "head_evidence",
        "missing_evidence"
      ],
      "properties": {
        "requirement_id": { "type": "string", "minLength": 1, "maxLength": 500 },
        "acai_id": { "type": "string", "minLength": 1, "maxLength": 500 },
        "title": { "type": "string", "maxLength": 2000 },
        "base_status": {
          "enum": ["satisfied", "partial", "missing", "unknown", "overreach", "invalid_evidence", "absent"]
        },
        "head_status": {
          "enum": ["satisfied", "partial", "missing", "unknown", "overreach", "invalid_evidence", "absent"]
        },
        "delta": {
          "enum": ["new_requirement", "removed_requirement", "improved", "regressed", "unchanged", "newly_in_scope"]
        },
        "reasons": {
          "type": "array",
          "maxItems": 10000,
          "items": { "type": "string", "maxLength": 6000 }
        },
        "head_evidence": {
          "type": "array",
          "maxItems": 100000,
          "items": { "$ref": "#/$defs/evidenceRef" }
        },
        "missing_evidence": {
          "type": "array",
          "maxItems": 100000,
          "items": { "$ref": "#/$defs/evidenceRef" }
        }
      }
    },
    "coverageCounts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["improved", "regressed", "unchanged", "new_requirement", "removed_requirement", "newly_in_scope"],
      "properties": {
        "improved": { "type": "integer", "minimum": 0 },
        "regressed": { "type": "integer", "minimum": 0 },
        "unchanged": { "type": "integer", "minimum": 0 },
        "new_requirement": { "type": "integer", "minimum": 0 },
        "removed_requirement": { "type": "integer", "minimum": 0 },
        "newly_in_scope": { "type": "integer", "minimum": 0 }
      }
    },
    "prCoverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["base_available", "summary", "in_scope_count", "deltas", "counts"],
      "properties": {
        "base_available": { "type": "boolean" },
        "summary": { "type": "string", "maxLength": 6000 },
        "in_scope_count": { "type": "integer", "minimum": 0 },
        "deltas": {
          "type": "array",
          "maxItems": 100000,
          "items": { "$ref": "#/$defs/coverageDelta" }
        },
        "counts": { "$ref": "#/$defs/coverageCounts" }
      }
    },
    "riskCandidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "rule", "category", "severity", "summary", "evidence", "suggested_checks"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 500 },
        "rule": {
          "enum": [
            "coverage_regression",
            "untested_changed_impl",
            "unmapped_change",
            "privacy_sensitive_change",
            "secret_in_diff",
            "comment_surface_change",
            "ci_secret_boundary_change",
            "schema_contract_change",
            "deleted_or_renamed_surface",
            "failed_or_skipped_test",
            "large_diff"
          ]
        },
        "category": {
          "enum": [
            "correctness",
            "security",
            "privacy",
            "maintainability",
            "architecture",
            "testing",
            "workflow",
            "release",
            "performance",
            "unknown"
          ]
        },
        "severity": { "enum": ["low", "medium", "high", "critical", "unknown"] },
        "summary": { "type": "string", "maxLength": 6000 },
        "evidence": {
          "type": "array",
          "maxItems": 100000,
          "items": { "$ref": "#/$defs/evidenceRef" }
        },
        "suggested_checks": {
          "type": "array",
          "maxItems": 10000,
          "items": { "type": "string", "maxLength": 6000 }
        }
      }
    },
    "prRisks": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "candidates"],
      "properties": {
        "summary": { "type": "string", "maxLength": 6000 },
        "candidates": {
          "type": "array",
          "maxItems": 100000,
          "items": { "$ref": "#/$defs/riskCandidate" }
        }
      }
    },
    "prDiagram": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "status", "body", "warnings"],
      "properties": {
        "path": { "type": "string", "minLength": 1, "maxLength": 4096 },
        "status": { "enum": ["valid", "invalid"] },
        "body": { "type": "string", "maxLength": 1000000 },
        "warnings": {
          "type": "array",
          "maxItems": 10000,
          "items": { "type": "string", "maxLength": 6000 }
        }
      }
    }
  }
}
