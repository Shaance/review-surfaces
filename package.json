{
  "name": "review-surfaces",
  "version": "0.1.0",
  "description": "Local-first review packet compiler for agent-generated code changes.",
  "bin": {
    "review-surfaces": "./bin/review-surfaces.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "pnpm run typecheck",
    "test": "pnpm run build && node --test dist/tests/*.test.js",
    "review-surfaces": "pnpm run build && node bin/review-surfaces.js",
    "copy-env": "./scripts/copy-env.sh"
  },
  "files": [
    "bin",
    "dist",
    "src",
    "types",
    "schemas",
    "scripts"
  ],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.8.0"
}
