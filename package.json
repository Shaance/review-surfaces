{
  "name": "review-surfaces",
  "version": "0.3.1",
  "description": "Evidence-bound audit of whether agent-written changes match the human-agent conversation.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Shaance/review-surfaces.git"
  },
  "homepage": "https://github.com/Shaance/review-surfaces#readme",
  "bugs": {
    "url": "https://github.com/Shaance/review-surfaces/issues"
  },
  "keywords": [
    "code-review",
    "ai-agents",
    "trust",
    "static-analysis",
    "diff",
    "local-first"
  ],
  "bin": {
    "review-surfaces": "./bin/review-surfaces.js",
    "agreement-audit": "./bin/agreement-audit.js"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "pnpm run clean && tsc -p tsconfig.json",
    "prepack": "pnpm run build",
    "build:fast": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "pnpm run typecheck",
    "test": "pnpm run build && node scripts/run-tests.mjs",
    "test:fast": "pnpm run build:fast && node scripts/run-tests.mjs",
    "test:watch": "pnpm run build:fast && node --test --watch dist/tests/*.test.js",
    "test:cov": "pnpm run build && node scripts/run-tests.mjs --coverage",
    "determinism-check": "./scripts/determinism-check.sh",
    "local-review": "./scripts/local-review.sh",
    "local-gate": "./scripts/local-gate.sh",
    "review-surfaces": "pnpm run build && node bin/review-surfaces.js",
    "agreement-audit": "node bin/agreement-audit.js",
    "agreement-audit:holdout-check": "node bin/agreement-audit.js benchmark-check --manifest bench/agreement/holdout/manifest.json --comparison bench/agreement/holdout/results.pending.json",
    "copy-env": "./scripts/copy-env.sh",
    "prepublishOnly": "pnpm run local-gate"
  },
  "files": [
    "bin",
    "dist/bin/bounded-stream-capture.js",
    "dist/bin/privacy-runtime.js",
    "dist/src",
    "schemas",
    "bench/agreement",
    "docs/example",
    "docs/agreement-audit-v0.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.8.0",
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "fast-xml-parser": "^5.8.0",
    "proper-lockfile": "4.1.2",
    "typescript": "^6.0.3",
    "yaml": "^2.9.0"
  },
  "optionalDependencies": {
    "@ai-sdk/anthropic": "^3.0.81",
    "@ai-sdk/google": "^3.0.80",
    "@ai-sdk/openai": "^3.0.66",
    "ai": "^6.0.192"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/proper-lockfile": "4.1.4"
  }
}
