.DS_Store

# Environment and local secrets
.env
.env.*
!.env.example

# Dependencies and package-manager caches
node_modules/
.pnpm-store/

# Build, coverage, and test output
dist/
build/
coverage/
.nyc_output/
tmp/
temp/

# Local agent/editor state
.claude/

# review-surfaces generated run artifacts. agent_handoff.md is GENERATED by
# `review-surfaces all --dogfood` (local-review) and goes stale if committed, so it is
# local-first only — agents regenerate it; AGENTS.md reads it "if it exists". Only
# human-authored feedback under feedback/ is tracked.
.review-surfaces/*
!.review-surfaces/feedback/
!.review-surfaces/feedback/*.yaml
.agreement-audit/

# review-surfaces effectiveness benchmark clone cache (BENCH.1)
bench/.cache/
